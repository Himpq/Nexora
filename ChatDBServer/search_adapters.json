{
    "version": 2,
    "relay_order": [
        "aliyun",
        "volcengine",
        "stepfun",
        "github",
        "suanli"
    ],
    "providers": {
        "volcengine": {
            "native_enabled": false,
            "relay_enabled": false,
            "allow_models": 1,
            "tools": [
                {
                    "type": "web_search"
                }
            ]
        },
        "aliyun": {
            "native_enabled": true,
            "relay_enabled": true,
            "allow_models": [
                "qwen3-max",
                "qwen3-max-preview",
                "qwen3-max-2025-09-23",
                "qwen3-max-2026-01-23",
                "qwen-max",
                "qwen-max-latest",
                "qwen-max-2024-09-19",
                "qwen3.5-plus",
                "qwen3.5-plus-2026-02-15",
                "qwen-plus",
                "qwen-plus-latest",
                "qwen-plus-2025-07-14",
                "qwen3.5-flash",
                "qwen3.5-flash-2026-02-23",
                "qwen-flash",
                "qwen-flash-2025-07-28",
                "qwen-turbo",
                "qwen-turbo-latest",
                "qwen-turbo-2025-07-15",
                "qwq-plus",
                "deepseek-v3.2",
                "deepseek-v3.2-exp",
                "deepseek-v3.1",
                "deepseek-r1-0528",
                "deepseek-r1",
                "deepseek-v3",
                "Moonshot-Kimi-K2-Instruct",
                "MiniMax-M2.1"
            ],
            "request_options": {
                "search_api": "chat_completions",
                "enable_search": true,
                "enable_thinking": true,
                "responses_fallback_to_chat": true,
                "responses_tools": [
                    {
                        "type": "web_search"
                    },
                    {
                        "type": "web_extractor"
                    },
                    {
                        "type": "code_interpreter"
                    }
                ]
            },
            "tools": [
                {
                    "type": "web_search"
                }
            ]
        },
        "github": {
            "native_enabled": false,
            "relay_enabled": false,
            "tools": []
        },
        "stepfun": {
            "native_enabled": false,
            "relay_enabled": false,
            "tools": []
        },
        "suanli": {
            "native_enabled": false,
            "relay_enabled": false,
            "tools": []
        }
    }
}
